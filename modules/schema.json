{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jordanpanov-lgtm.github.io/hist-map/modules/schema.json",
  "title": "Hist-Map Folio",
  "description": "Machine-checkable contract for a single folio file. The human companion is GROUPING_GUIDE.md; where the two disagree, this schema is what CI enforces. Referential rules that JSON Schema cannot express (region/period_label validity against config/regions.js, timeline entryId resolution, xlink resolution across folios) are enforced by validate.js.",
  "type": "object",
  "required": ["id", "title", "subtitle", "period", "region", "period_label", "mapCenter", "mapZoom", "categories", "timeline"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "subtitle": { "type": "string", "minLength": 1 },
    "period": {
      "type": "object",
      "required": ["start", "end"],
      "properties": {
        "start": { "type": "integer" },
        "end": { "type": "integer" }
      }
    },
    "region": { "type": "string", "minLength": 1 },
    "period_label": { "type": "string", "minLength": 1 },
    "mapCenter": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 2,
      "maxItems": 2
    },
    "mapZoom": { "type": "number" },
    "categories": {
      "type": "array",
      "items": { "$ref": "#/$defs/category" }
    },
    "timeline": {
      "type": "array",
      "items": { "$ref": "#/$defs/lane" }
    }
  },
  "$defs": {
    "category": {
      "type": "object",
      "required": ["id", "label", "icon", "color", "accent", "bg", "entries"],
      "properties": {
        "id": {
          "type": "string",
          "enum": ["power", "conflict", "order", "belief", "expression", "thought", "economy", "technology", "exchange", "world", "lives"]
        },
        "label": { "type": "string", "minLength": 1 },
        "icon": { "type": "string" },
        "color": { "type": "string" },
        "accent": { "type": "string" },
        "bg": { "type": "string" },
        "subtitle": { "type": "string" },
        "entries": {
          "type": "array",
          "items": { "$ref": "#/$defs/entry" }
        }
      }
    },
    "entry": {
      "type": "object",
      "required": ["id", "group", "label", "date", "loc", "coords", "hint", "tag", "note"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "group": { "type": "string", "minLength": 1 },
        "dynasty": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "date": { "type": "string", "minLength": 1 },
        "loc": { "type": "string", "minLength": 1 },
        "coords": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "prefixItems": [
            { "type": "number", "minimum": -90, "maximum": 90 },
            { "type": "number", "minimum": -180, "maximum": 180 }
          ]
        },
        "hint": { "type": "string", "minLength": 1 },
        "tag": { "type": "string", "minLength": 1 },
        "note": { "type": "string", "minLength": 1 },
        "keywords": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "xlinks": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9-]+::.+$" }
        }
      }
    },
    "lane": {
      "type": "object",
      "required": ["id", "label", "events"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "icon": { "type": "string" },
        "accent": { "type": "string" },
        "label": { "type": "string", "minLength": 1 },
        "events": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["y", "l", "entryId"],
            "properties": {
              "y": { "type": "integer" },
              "y2": { "type": "integer" },
              "l": { "type": "string", "minLength": 1 },
              "entryId": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
